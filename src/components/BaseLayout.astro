---
// BaseLayout.astro
// Props: title (string), description (string, optional)
const { title, description = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Etcetera</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="/styles/global.css" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Etcetera",
      "url": "https://etcetera-notesfromthemiddleofthinking.netlify.app/"
    }
  </script>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>
          <a href="/">Etcetera: Notes from the Middle of Thinking</a>
        </h1>
      </header>

      <main>
        <slot />
      </main>
    </div> <footer style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #ddd; text-align: center; background-color: #f8f8f8;">
      <div class="container"> <p style="font-size: 0.9rem; color: #555;">
          © {new Date().getFullYear()} Etcetera. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>