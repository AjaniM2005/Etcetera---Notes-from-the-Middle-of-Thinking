---
// PostCard.astro
// Props: title, date, slug, tags (array of strings), and Content component
const { title, date, slug, tags, content: Content } = Astro.props;
---

<article class="post-card" data-tags={tags.join(',')}>
  <h2>
    <a href={`/posts/${slug}/`}>{title}</a>
  </h2>
  <p style="color: #555; font-size: 0.9rem;">{new Date(date).toLocaleDateString()}</p>
  
  <div class="excerpt-preview">
    <Content />
  </div>

  <div style="margin-top: 1rem;">
    {tags.map((tag) => (
      <span class="tag-pill">{tag}</span>
    ))}
  </div>
</article>

<style>
  /* 🪄 This handles line-clamping so it cuts off nicely after 3 lines */
  .excerpt-preview {
    display: -webkit-box;
    -webkit-line-clamp: 3; 
    -webkit-box-orient: vertical;  
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  /* Style your links inside the excerpt preview box */
  .excerpt-preview :global(a) {
    color: #3b82f6;
    text-decoration: underline;
  }
</style>